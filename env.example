version: "3.9"

services:
  db:
    image: postgres:16-alpine
    restart: unless-stopped
    environment:
      POSTGRES_USER: quantpilot
      POSTGRES_PASSWORD: quantpilot_dev_password
      POSTGRES_DB: quantpilot
    ports:
      - "5432:5432"
    volumes:
      - quantpilot_pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U quantpilot"]
      interval: 5s
      timeout: 5s
      retries: 5

  app:
    build: .
    restart: unless-stopped
    depends_on:
      db:
        condition: service_healthy
    environment:
      DATABASE_URL: postgresql://quantpilot:quantpilot_dev_password@db:5432/quantpilot
      OPENAI_API_KEY: ${OPENAI_API_KEY}
    ports:
      - "8000:8000"
    volumes:
      - .:/app

volumes:
  quantpilot_pgdata:
